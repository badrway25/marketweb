+
+    def test_csrf_failure_renders_branded_template(self):
+        """Calling django.views.csrf.csrf_failure picks up our
+        template/403_csrf.html via the CSRF_FAILURE_TEMPLATE_NAME
+        auto-discovery (default = "403_csrf.html")."""
