# MarketWeb · environment template (Sprint 0 · T1+T2+T3)
#
# Copy to `.env` and fill in. None of the values below are loaded
# automatically — Django reads them from the OS environment. Pick your
# preferred loader:
#
#   PowerShell (one-shot):
#     Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { Set-Item env:$($matches[1]) $matches[2] } }
#
#   bash / zsh (one-shot):
#     set -a; source .env; set +a
#
#   docker / docker-compose:
#     services.web.env_file: .env
#
#   systemd unit:
#     EnvironmentFile=/etc/marketweb.env
#
# `.env` is .gitignored — do NOT commit real secrets.
#
# ──────────────────────────────────────────────────────────────────────
# Profile selector
# ──────────────────────────────────────────────────────────────────────
#
# `manage.py` defaults to `marketweb.settings.dev`.
# `wsgi.py` / `asgi.py` default to `marketweb.settings.prod`.
# Override here only if you need a non-default combination (e.g. testing
# the prod profile locally with `python manage.py runserver`).
#
# DJANGO_SETTINGS_MODULE=marketweb.settings.prod


# ──────────────────────────────────────────────────────────────────────
# Core (REQUIRED in prod, optional in dev)
# ──────────────────────────────────────────────────────────────────────

# 50+ random characters. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

# Comma-separated list. Required in prod; the wildcard `*` is rejected.
# Dev auto-includes localhost / 127.0.0.1 / testserver / 0.0.0.0 even
# when this is unset.
DJANGO_ALLOWED_HOSTS=marketweb.example.com,www.marketweb.example.com

# Comma-separated list of `https://` origins that may POST forms.
# REQUIRED in prod (admin login, signup, autosave all break without it).
DJANGO_CSRF_TRUSTED_ORIGINS=https://marketweb.example.com,https://www.marketweb.example.com

# 1 / 0 — defaults: dev=1, prod=0. Override here only intentionally.
DJANGO_DEBUG=0

# Root logger level: DEBUG, INFO, WARNING, ERROR. Default INFO.
DJANGO_LOG_LEVEL=INFO
# Set to DEBUG only for SQL-level diagnostics (very noisy).
DJANGO_DB_LOG_LEVEL=WARNING


# ──────────────────────────────────────────────────────────────────────
# SECURE_* (prod only — sane defaults; tweak when ramping HTTPS)
# ──────────────────────────────────────────────────────────────────────

# 1 = redirect every HTTP request to HTTPS. Disable on day 1 of an
# HTTPS migration if your edge is still mixed.
DJANGO_SECURE_SSL_REDIRECT=1

# 1 year HSTS. Set to 0 (disable HSTS) on day 1; ramp to 60 (1 minute),
# 86400 (1 day), 604800 (1 week), 31536000 (1 year) once HTTPS is solid.
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1


# ──────────────────────────────────────────────────────────────────────
# Database (prod only — SQLite is auto-used in dev)
# ──────────────────────────────────────────────────────────────────────
#
# Set DATABASE_NAME to switch on the prod DATABASES dict. Without it,
# the prod profile refuses to start unless DJANGO_ALLOW_SQLITE_PROD=1
# (strongly discouraged — SQLite on a container's ephemeral disk loses
# every order on restart).

DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=marketweb
DATABASE_USER=marketweb
DATABASE_PASSWORD=
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
# Persistent connection pool (seconds); 0 disables.
DATABASE_CONN_MAX_AGE=60

# Escape hatch — use ONLY for short-lived staging or smoke tests.
# DJANGO_ALLOW_SQLITE_PROD=1


# ──────────────────────────────────────────────────────────────────────
# Email (prod only — dev uses console.EmailBackend)
# ──────────────────────────────────────────────────────────────────────

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL=noreply@marketweb.example.com


# ──────────────────────────────────────────────────────────────────────
# Stripe (optional — storefronts default to the stub provider)
# ──────────────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Default behaviour:
#   dev  → 1 (missing key = stub fallback, log warning, dev keeps moving)
#   prod → 0 (missing key = hard error in dispatcher, no silent stub)
STRIPE_ALLOW_STUB_FALLBACK=0


# ──────────────────────────────────────────────────────────────────────
# Sentry SDK observability (T19 · prod only · entirely optional)
# ──────────────────────────────────────────────────────────────────────
#
# Init is gated by SENTRY_DSN. Leave empty (or unset) and the helper
# in `marketweb/sentry.py` is a no-op — dev / CI / local stay silent
# and never call sentry_sdk.init. Set the DSN at deploy time to opt
# the prod profile into error reporting.
#
# Get a DSN from your Sentry project's Settings → Client Keys (DSN).

SENTRY_DSN=

# Tag every event with the deployment environment. Useful when one
# Sentry project receives events from staging + production + ad-hoc
# preview deploys. Defaults to "production" when SENTRY_DSN is set.
SENTRY_ENVIRONMENT=production

# Tag every event with the release identifier (commit sha, semver,
# build number — your call). Leave empty to let the SDK auto-detect
# from git when running inside a checked-out repo.
SENTRY_RELEASE=

# Performance / tracing budget. 0.0 = errors only (default).
# Bump cautiously — every traced request costs Sentry quota.
#   0.05 = 5% sampled, sane starting point on a low-volume site.
SENTRY_TRACES_SAMPLE_RATE=0.0

# Profiling budget. 0.0 = no profiling (default). Profiles inherit
# the trace sample rate, so this is a multiplier on top of traces.
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Send default PII (request body, user IP, cookies). Defaults to off
# for privacy. Flip to 1 only after a privacy review.
SENTRY_SEND_DEFAULT_PII=0


# ──────────────────────────────────────────────────────────────────────
# django-axes brute-force protection (T23 · always on except in tests)
# ──────────────────────────────────────────────────────────────────────
#
# Lockout policy: AXES_FAILURE_LIMIT failed (ip, username) attempts
# trigger a 429 lockout for AXES_COOLOFF_TIME_HOURS. Combo key keeps
# a single attacker from locking out everyone behind a NAT IP.
#
# Auto-disabled when `manage.py test` runs (so the Django test
# client's `Client.login()` shortcut keeps working). The lockout
# logic itself is exercised by `apps/core/tests.py::AxesLockoutTests`
# which re-enables axes locally.

# Master kill-switch. Override to 0 only for break-glass debug.
AXES_ENABLED=1

# Lockout threshold + duration. Defaults below = 5 fails / 1 hour.
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME_HOURS=1

# Surface lockout events in the standard logger. Set to 0 only if
# the noise becomes a problem.
AXES_VERBOSE=1

# Reverse-proxy hop count. 0 = trust REMOTE_ADDR (single-host dev).
# Set to 1 if behind nginx / Traefik / a single load balancer
# forwarding X-Forwarded-For. Set to 2+ behind a CDN+LB chain.
AXES_IPWARE_PROXY_COUNT=0


# ──────────────────────────────────────────────────────────────────────
# Admin 2FA · OTP session re-verification policy (T29 · admin only)
# ──────────────────────────────────────────────────────────────────────
#
# Cap on the OTP-verified state lifetime on /admin/ requests,
# INDEPENDENT of SESSION_COOKIE_AGE. After this many seconds the
# admin is forced to re-enter password + TOTP — even though their
# auth session is still valid — when they next hit any /admin/ path.
#
# Default 28800 = 8 hours (one work-day). Customer flow is
# unaffected (T29 is path-scoped at /admin/).
#
# Tighten for sensitive contexts:
#   OTP_ADMIN_REVERIFY_SECONDS=3600  → 1h re-prompts
#   OTP_ADMIN_REVERIFY_SECONDS=900   → 15min re-prompts (lab/sandbox)

OTP_ADMIN_REVERIFY_SECONDS=28800


# ──────────────────────────────────────────────────────────────────────
# Audit log retention + alerting (T32)
# ──────────────────────────────────────────────────────────────────────
#
# T31 ships an AuditLogEntry feed at /admin/core/auditlogentry/.
# T32 caps its lifetime and pushes alerts on the most sensitive
# actions.

# Retention window. ``python manage.py prune_audit_log`` deletes
# rows older than this many days. 365 = one year (default, covers
# most compliance review windows). Lower for cost-sensitive deploys.
AUDIT_LOG_RETENTION_DAYS=365

# Recipients for high-sensitivity audit alerts (ROLE_CHANGED, DELETED).
# Comma-separated email list. Empty = no email (the dev default; the
# logger WARNING still fires).
#   AUDIT_ALERT_RECIPIENTS=ops@example.com,founder@example.com
AUDIT_ALERT_RECIPIENTS=

# Kill-switch for the alert receiver — break-glass only. Default ON.
AUDIT_ALERTS_ENABLED=1
